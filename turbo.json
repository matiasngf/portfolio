{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "experiment-build": {
      "outputs": ["dist/**", ".next/**"],
      "cache": true
    },
    "experiments-server-build": {
      "dependsOn": ["^experiment-build"],
      "outputs": ["dist/**", ".next/**"],
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "preview": {
      "cache": false
    }
  }
}
